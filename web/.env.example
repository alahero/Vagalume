# Copia a `.env` o define en Vercel → Environment Variables
# Origen público del sitio (Open Graph, canonical, JSON-LD). Sin barra final.
# VITE_SITE_ORIGIN=https://www.vagalumetulum.com

# Proxy de Vite: origen donde corre `vercel dev` (raíz del repo) para `/api/*`.
# Por defecto el proxy apunta a http://127.0.0.1:3000 si no defines esta variable.
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# La clave MandalaTickets va en Vercel (Variables de entorno del proyecto) y en `.env`
# del proceso de `vercel dev` en la RAÍZ del repo — NUNCA como VITE_* (no exponer al bundle).
# MT_NEW_API_KEY=tu_clave_aqui
